# .env.sample — workstation configuration reference for this cluster.
#
# ARCHITECTURE NOTE: The old envsubst / deploy.sh pipeline and its DEPLOY_*
# toggles, CLUSTER_NODES / CLUSTER_NODES_HOSTNAMES, and MOUNT_USB_* variables
# have been REMOVED. Node provisioning is now Ansible (ansible/); app on/off
# is controlled by ArgoCD Application presence (GitOps).
#
# This file is NOT sourced automatically by any script. Use it as a reference
# when configuring your workstation or adapting the repo to a new cluster.
#
# WHERE VALUES LIVE TODAY:
#   • Non-secret, cluster-specific values (hostname suffix, LAN IPs, timezone,
#     UID/GID, ACME email) — components/cluster-config/kustomization.yml
#   • Per-app non-secret config — apps/<app>/.env (committed per app)
#   • Secrets — 1Password items; pushed by scripts/sync-secrets.sh.
#     Run scripts/seed-1password.sh to create the item/field skeleton, then
#     set real values in the 1Password app. See docs/secrets.md.
#   • Longhorn / platform chart versions — platform/<stack>/helm-values.yaml
#     and the Application version pin in clusters/rpi/platform-apps.yml.

# ─────────────────────────────────────────────────────────────────────────────
# 1PASSWORD / PUSH-SYNC
# Export these before running scripts/sync-secrets.sh or scripts/seed-1password.sh.
# ─────────────────────────────────────────────────────────────────────────────
OP_VAULT=homelab
OP_ACCOUNT=

# ─────────────────────────────────────────────────────────────────────────────
# CLUSTER-CONFIG — non-secret, cluster-specific
# Canonical location: components/cluster-config/kustomization.yml
# Edit the kustomization.yml directly; the values below are placeholders
# documenting what to customise — they are NOT exported env vars.
# ─────────────────────────────────────────────────────────────────────────────

# Internal hostname suffix for *.your-domain-style Ingress hosts
HOSTNAME_SUFFIX=your-domain.example
# MetalLB Layer-2 VIP for DNS (dnsdist Service + metallb IPAddressPool)
LAN_LB_IP=192.0.2.53
# MetalLB Layer-2 VIP for Ingress (Traefik Service + metallb IPAddressPool)
INGRESS_LB_IP=192.0.2.80
# Let's Encrypt ACME contact email (cert-manager ClusterIssuer)
ACME_EMAIL=admin@your-domain.example
TZ=America/Detroit
PUID=1000
PGID=1000

# ─────────────────────────────────────────────────────────────────────────────
# PER-APP NON-SECRET CONFIG
# Canonical location: apps/<app>/.env (committed per app — edit there directly)
# Listed here as a reference for cluster-specific values an operator must set.
# ─────────────────────────────────────────────────────────────────────────────

# Pi-hole (apps/pihole/.env) — reverse DNS server list (semicolon-delimited, quirky #port syntax)
LAN_REV_SERVERS=true,192.168.0.0/24,192.168.0.1#53,home.arpa

# Shlink (apps/shlink/.env) — public short-link domain (not the internal suffix)
SHLINK_DEFAULT_DOMAIN=your-shortlink-domain.example

# PostgreSQL username — config, not a secret (apps/data and postgres-client app .env files)
POSTGRES_USER=rpi

# Monitoring — Windows exporter static scrape target (platform/monitoring helm-values.yaml)
WMI_IP_ADDRESS=192.0.2.123

# Uptime Kuma (apps/uptime/.env)
UPTIME_NODE=rpi001
UPTIME_BACKUP_SCHEDULE=0 0 * * *
UPTIME_BACKUP_RETENTION_DAYS=14

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS — 1PASSWORD ITEM STRUCTURE (op:// reference format)
# These are NOT env vars to export. They document the 1Password vault/item/field
# paths used in secrets/templates/*.yaml and resolved by scripts/sync-secrets.sh.
# Run scripts/seed-1password.sh to scaffold the items, then set real values in
# the 1Password app. Never commit real values here. See docs/secrets.md.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (platform/data server secret + fanned out to postgres-client namespaces)
POSTGRES_PASSWORD=op://homelab/postgres/password

# Shlink
SHLINK_API_KEY=op://homelab/shlink/SHLINK_SERVER_API_KEY
SHLINK_GEOIP_LICENSE_KEY=op://homelab/shlink/GEOLITE_LICENSE_KEY

# Grafana admin (platform/monitoring)
GRAFANA_ADMIN_PASSWORD=op://homelab/grafana/admin-password

# Pi-hole web UI
PIHOLE_WEBPASSWORD=op://homelab/pihole/FTLCONF_webserver_api_password

# Traefik basic-auth (htpasswd line — generate: htpasswd -nbB user pass)
TRAEFIK_BASICAUTH=op://homelab/traefik/basicauth

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=op://homelab/keycloak/KEYCLOAK_ADMIN_PASSWORD

# Pikaraoke
PIKARAOKE_ADMIN_PASSWORD=op://homelab/pikaraoke/PIKARAOKE_ADMIN_PASSWORD

# Uptime Kuma (same item also referenced by monitoring scrape config)
UPTIME_USERNAME=op://homelab/uptime/UPTIME_USERNAME
UPTIME_PASSWORD=op://homelab/uptime/UPTIME_PASSWORD

# Meal Planner (DATABASE_URL is the full Postgres connection string — see docs/secrets.md)
MEAL_PLANNER_DATABASE_URL=op://homelab/meal-planner/DATABASE_URL
MEAL_PLANNER_JWT_SECRET=op://homelab/meal-planner/JWT_SECRET
MEAL_PLANNER_GOOGLE_CLIENT_ID=op://homelab/meal-planner/GOOGLE_CLIENT_ID
MEAL_PLANNER_GOOGLE_CLIENT_SECRET=op://homelab/meal-planner/GOOGLE_CLIENT_SECRET

# Nebulasync
NEBULASYNC_PRIMARY=op://homelab/nebulasync/PRIMARY
NEBULASYNC_REPLICAS=op://homelab/nebulasync/REPLICAS