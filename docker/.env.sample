# Secrets for the standalone Docker Compose stacks under docker/.
# Copy to docker/.env (gitignored) and set real values, then run e.g.:
#   docker compose --env-file docker/.env -f docker/scrypted.yml up -d
#
# NOTE: the previously committed Scrypted/Watchtower token is exposed in git
# history and MUST be rotated.
SCRYPTED_WEBHOOK_UPDATE_AUTHORIZATION=
WATCHTOWER_HTTP_API_TOKEN=
