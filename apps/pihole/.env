# cluster-specific: ADMIN_EMAIL
ADMIN_EMAIL=admin@themartinez.cloud
FTLCONF_database_DBinterval=900
FTLCONF_database_maxDBdays=7
FTLCONF_database_network_expire=7
FTLCONF_dns_blocking_mode=NX
FTLCONF_dns_cache_size=0
FTLCONF_dns_listeningMode=all
FTLCONF_dns_rateLimit_count=2000
FTLCONF_dns_rateLimit_interval=60
FTLCONF_dns_replyWhenBusy=allow
# cluster-specific: LAN_REV_SERVERS
FTLCONF_dns_revServers=true,192.168.16.0/20,192.168.16.1#53,home.arpa;true,192.168.52.0/22,192.168.52.1#53,home.arpa;true,192.168.2.0/24,192.168.2.1#53,home.arpa
FTLCONF_dns_upstreams=10.43.100.20#53;1.1.1.1#53
FTLCONF_misc_check_disk=85
#FTLCONF_misc_delay_startup=30
FTLCONF_webserver_interface_theme=default-dark
FTLCONF_webserver_port=80
FTLCONF_webserver_session_timeout=86400
# cluster-specific: PGID
PIHOLE_GID=1000
# cluster-specific: PUID
PIHOLE_UID=1000
# cluster-specific: TZ
TZ=America/Detroit
